# IDE / Editor settings
.vscode/settings.json

# Environment files with secrets
.env
.env.local
.env.*.local

# Frontend specific
frontend/.env
frontend/.env.local
frontend/.env.*.local

# Backend specific
backend/.env
backend/src/main/resources/application-local.yml

# Keep example files
!**/.env.example
sample-files/*.pcap
!sample-files/demo_all_rules.pcap

# Docker image tarballs (generated by scripts/pull-and-save-images.sh)
images/*.tar
